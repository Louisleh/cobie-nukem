# Copy this file to resources/content/<mission>_manifest.tres and replace every
# TEMPLATE value. Add typed ext_resource declarations for DifficultyProfile,
# ObjectiveDefinition, and EncounterDefinition as shown in
# resources/content/salmon_creek_manifest.tres.
[gd_resource type="Resource" script_class="ContentManifest" load_steps=2 format=3]

[ext_resource type="Script" path="res://scripts/gameplay/content_manifest.gd" id="1"]

[resource]
script = ExtResource("1")
content_version = 1
level_id = &"TEMPLATE_LEVEL_ID"
level_scene = "res://scenes/levels/TEMPLATE_LEVEL.tscn"
